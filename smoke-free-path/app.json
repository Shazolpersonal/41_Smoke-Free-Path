{
  "expo": {
    "name": "ধোঁয়া-মুক্ত পথ",
    "slug": "smoke-free-path",
    "scheme": "smokefree",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/custom-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F9F9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smokefree.path",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.smokefree.path",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2E7D32",
          "sounds": []
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Amiri-Regular.ttf"]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e73e6816-ebb7-40b7-9dec-e4b3b3661515"
      }
    }
  }
}
